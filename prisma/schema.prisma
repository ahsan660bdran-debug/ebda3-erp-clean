// prisma/schema.prisma
// EBDA3 ERP — Admin MVP

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum UserRole {
  ADMIN
}

enum OrderStatus {
  SCHEDULED
  INSTALLED
  UNINSTALLED
}

enum ProductCategory {
  HANGER
  IRONING_TABLE
}

enum DiscountType {
  FIXED
  PERCENT
}

enum AssignmentMode {
  FIXED
  ROTATION
  MANUAL
}

// ─────────────────────────────────────────
// USER
// ─────────────────────────────────────────

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ADMIN)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([email])
  @@map("users")
}

// ─────────────────────────────────────────
// ZONE
// ─────────────────────────────────────────

model Zone {
  id                String         @id @default(cuid())
  name              String         @unique
  assignmentMode    AssignmentMode @default(MANUAL)
  autoAssignEnabled Boolean        @default(true)
  fixedAgentId      String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  fixedAgent        Agent?         @relation("ZoneFixedAgent", fields: [fixedAgentId], references: [id], onDelete: SetNull)
  agents            ZoneAgent[]
  customers         Customer[]
  orders            Order[]

  @@index([fixedAgentId])
  @@map("zones")
}

// ─────────────────────────────────────────
// ZONE AGENT (Rotation)
// ─────────────────────────────────────────

model ZoneAgent {
  id            String  @id @default(cuid())
  zoneId        String
  agentId       String
  rotationOrder Int
  isActive      Boolean @default(true)

  zone          Zone    @relation(fields: [zoneId], references: [id], onDelete: Cascade)
  agent         Agent   @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@unique([zoneId, agentId])
  @@unique([zoneId, rotationOrder])
  @@index([zoneId, isActive, rotationOrder])
  @@map("zone_agents")
}

// ─────────────────────────────────────────
// CUSTOMER
// ─────────────────────────────────────────

model Customer {
  id        String   @id @default(cuid())
  fullName  String
  phone     String   @unique
  emirate   String
  area      String?
  zoneId    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  zone      Zone?    @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  orders    Order[]

  @@index([phone])
  @@index([zoneId])
  @@map("customers")
}

// ─────────────────────────────────────────
// PRODUCT
// ─────────────────────────────────────────

model Product {
  id        String          @id @default(cuid())
  name      String
  category  ProductCategory
  basePrice Decimal         @db.Decimal(10, 2)
  isActive  Boolean         @default(true)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  orderItems OrderItem[]

  @@index([category])
  @@index([isActive])
  @@map("products")
}

// ─────────────────────────────────────────
// AGENT
// ─────────────────────────────────────────

model Agent {
  id        String   @id @default(cuid())
  fullName  String
  phone     String   @unique
  email     String?  @unique
  emirate   String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders          Order[]
  zoneAgents      ZoneAgent[]
  fixedInZones    Zone[]      @relation("ZoneFixedAgent")

  @@index([isActive])
  @@map("agents")
}

// ─────────────────────────────────────────
// ORDER
// ─────────────────────────────────────────

model Order {
  id             String       @id @default(cuid())
  orderNumber    String       @unique
  status         OrderStatus  @default(SCHEDULED)
  scheduledAt    DateTime?
  installedAt    DateTime?
  discountType   DiscountType?
  discountValue  Decimal?     @db.Decimal(10, 2)
  subtotal       Decimal      @db.Decimal(10, 2)
  discountAmount Decimal      @default(0) @db.Decimal(10, 2)
  total          Decimal      @db.Decimal(10, 2)
  notes          String?
  customerId     String
  agentId        String?
  zoneId         String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  customer       Customer     @relation(fields: [customerId], references: [id], onDelete: Restrict)
  agent          Agent?       @relation(fields: [agentId], references: [id], onDelete: SetNull)
  zone           Zone?        @relation(fields: [zoneId], references: [id], onDelete: SetNull)
  items          OrderItem[]

  @@index([orderNumber])
  @@index([status])
  @@index([customerId])
  @@index([agentId])
  @@index([zoneId])
  @@index([scheduledAt])
  @@index([createdAt])
  @@index([status, scheduledAt])
  @@index([status, agentId])
  @@index([zoneId, createdAt])
  @@map("orders")
}

// ─────────────────────────────────────────
// ORDER ITEM
// ─────────────────────────────────────────

model OrderItem {
  id        String   @id @default(cuid())
  qty       Int
  unitPrice Decimal  @db.Decimal(10, 2)
  lineTotal Decimal  @db.Decimal(10, 2)
  orderId   String
  productId String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product   Product  @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@map("order_items")
}
